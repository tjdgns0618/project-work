### 커피 주문 서비스 — 전체 API 테스트 (HTTP Client)
#
# 사전 조건
#  1) 인프라 기동:  docker compose up -d      (MySQL 3307 / Redis 6379 / Kafka 9092)
#  2) 앱 실행:      DB_PORT=3307 로 부팅       (application.yml 기본값이 3306이므로 로컬 3307 매핑에 맞춤)
#  3) 커피 메뉴 시드 (메뉴 생성 API는 과제 범위 밖):
#     docker exec coffee-mysql mysql -uroot -proot coffee \
#       -e "INSERT INTO coffees(name,price) VALUES('아메리카노',4000),('카페라떼',4500),('바닐라라떼',5000);"
#
# 사용법: IntelliJ Ultimate 또는 VS Code REST Client에서 각 ### 블록의 실행 버튼을 누른다.
#         위에서 아래로 순서대로 실행하면 memberId·coffeeId가 캡처되어 흐름이 이어진다.

@baseUrl = http://localhost:8080/api/v1

###############################################################################
# 정상 흐름 (1 → 5)
###############################################################################

### 1. 회원 가입 (201) — memberId 캡처
POST {{baseUrl}}/members
Content-Type: application/json

{
  "email": "buyer_{{$uuid}}@example.com",
  "password": "P@ssw0rd!",
  "name": "김구매"
}

> {%
    client.test("회원 가입 201", function () {
        client.assert(response.status === 201, "status=" + response.status);
    });
    client.global.set("memberId", response.body.data.id);
%}

### 2. 커피 메뉴 목록 조회 (200) — 첫 메뉴의 coffeeId 캡처
GET {{baseUrl}}/coffees

> {%
    client.test("메뉴 조회 200", function () {
        client.assert(response.status === 200, "status=" + response.status);
    });
    client.test("메뉴가 시드되어 있는가", function () {
        client.assert(response.body.data.length > 0, "coffees 테이블이 비어 있음 — 사전 조건 3) 시드 필요");
    });
    if (response.body.data.length > 0) {
        client.global.set("coffeeId", response.body.data[0].id);
    }
%}

### 3. 포인트 충전 (200)
POST {{baseUrl}}/members/{{memberId}}/points
Content-Type: application/json

{
  "amount": 100000
}

> {%
    client.test("충전 200", function () {
        client.assert(response.status === 200, "status=" + response.status);
        client.assert(response.body.data.pointBalance >= 100000, "잔액 반영 안 됨");
    });
%}

### 4. 커피 주문 / 결제 (201)
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "memberId": {{memberId}},
  "coffeeId": {{coffeeId}}
}

> {%
    client.test("주문 201", function () {
        client.assert(response.status === 201, "status=" + response.status);
        client.assert(response.body.data.payAmount > 0, "결제 금액 없음");
    });
%}

### 5. 인기 메뉴 목록 조회 (200)
# 주문 이벤트가 Kafka Consumer를 거쳐 Redis에 적재되기까지 약간의 지연이 있을 수 있다.
GET {{baseUrl}}/coffees/popular

> {%
    client.test("인기 메뉴 200", function () {
        client.assert(response.status === 200, "status=" + response.status);
    });
%}

###############################################################################
# 실패 케이스
###############################################################################

### 1-a. 회원 가입 — 필수값 누락 (400)
POST {{baseUrl}}/members
Content-Type: application/json

{
  "email": "",
  "password": "P@ssw0rd!",
  "name": "김구매"
}

> {% client.test("400", function () { client.assert(response.status === 400, "status=" + response.status); }); %}

### 1-b. 회원 가입 — 이메일 중복 준비 (최초 1회 성공/이미 있으면 409)
POST {{baseUrl}}/members
Content-Type: application/json

{
  "email": "dup@example.com",
  "password": "P@ssw0rd!",
  "name": "중복회원"
}

### 1-c. 회원 가입 — 이메일 중복 (409)
POST {{baseUrl}}/members
Content-Type: application/json

{
  "email": "dup@example.com",
  "password": "P@ssw0rd!",
  "name": "중복회원"
}

> {% client.test("409", function () { client.assert(response.status === 409, "status=" + response.status); }); %}

### 3-a. 포인트 충전 — 금액 0 이하 (400)
POST {{baseUrl}}/members/{{memberId}}/points
Content-Type: application/json

{
  "amount": 0
}

> {% client.test("400", function () { client.assert(response.status === 400, "status=" + response.status); }); %}

### 3-b. 포인트 충전 — 존재하지 않는 회원 (404)
POST {{baseUrl}}/members/99999999/points
Content-Type: application/json

{
  "amount": 1000
}

> {% client.test("404", function () { client.assert(response.status === 404, "status=" + response.status); }); %}

### 4-a. 주문 — 필수값 누락 (400)
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "memberId": {{memberId}}
}

> {% client.test("400", function () { client.assert(response.status === 400, "status=" + response.status); }); %}

### 4-b. 주문 — 존재하지 않는 메뉴 (404)
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "memberId": {{memberId}},
  "coffeeId": 99999999
}

> {% client.test("404", function () { client.assert(response.status === 404, "status=" + response.status); }); %}

### 4-c. 주문 — 존재하지 않는 회원 (404)
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "memberId": 99999999,
  "coffeeId": {{coffeeId}}
}

> {% client.test("404", function () { client.assert(response.status === 404, "status=" + response.status); }); %}

### 4-d. 주문 — 잔액 부족 준비: 충전 안 한 새 회원 생성 (poorId 캡처)
POST {{baseUrl}}/members
Content-Type: application/json

{
  "email": "poor_{{$uuid}}@example.com",
  "password": "P@ssw0rd!",
  "name": "무일푼"
}

> {% client.global.set("poorId", response.body.data.id); %}

### 4-e. 주문 — 잔액 0 회원 주문 시 포인트 부족 (409)
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "memberId": {{poorId}},
  "coffeeId": {{coffeeId}}
}

> {% client.test("409", function () { client.assert(response.status === 409, "status=" + response.status); }); %}
